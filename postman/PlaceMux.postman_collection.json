{
  "info": {
    "name": "PlaceMux API — Mock",
    "description": "Task 2 mock API for the PlaceMux placement platform. Set the `baseUrl` environment variable to http://localhost:3000/api/v1 before running.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] } },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('returns 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /ready",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/ready", "host": ["{{baseUrl}}"], "path": ["ready"] } }
        }
      ]
    },
    {
      "name": "Students",
      "item": [
        {
          "name": "List students",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/students", "host": ["{{baseUrl}}"], "path": ["students"] } },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('returns 200', () => pm.response.to.have.status(200));",
                  "pm.test('uses the standard envelope', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('success', true);",
                  "  pm.expect(body).to.have.property('data');",
                  "  pm.expect(body).to.have.property('meta');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "List students - filter status=seeking limit=2",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/students?status=seeking&limit=2",
              "host": ["{{baseUrl}}"],
              "path": ["students"],
              "query": [
                { "key": "status", "value": "seeking" },
                { "key": "limit", "value": "2" }
              ]
            }
          }
        },
        {
          "name": "List students - bad page (400)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/students?page=0",
              "host": ["{{baseUrl}}"],
              "path": ["students"],
              "query": [{ "key": "page", "value": "0" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('returns 400', () => pm.response.to.have.status(400));",
                  "pm.test('error code is BAD_REQUEST', () => {",
                  "  pm.expect(pm.response.json().error.code).to.equal('BAD_REQUEST');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get student stu_001",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/students/stu_001", "host": ["{{baseUrl}}"], "path": ["students", "stu_001"] } }
        },
        {
          "name": "Get student stu_999 (404)",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/students/stu_999", "host": ["{{baseUrl}}"], "path": ["students", "stu_999"] } },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('returns 404', () => pm.response.to.have.status(404));",
                  "pm.test('error code is RESOURCE_NOT_FOUND', () => {",
                  "  pm.expect(pm.response.json().error.code).to.equal('RESOURCE_NOT_FOUND');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create student (201)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Kabir Menon\",\n  \"email\": \"kabir.menon@example.edu\",\n  \"branch\": \"Computer Science\",\n  \"graduationYear\": 2027,\n  \"cgpa\": 8.2,\n  \"skills\": [\"Node.js\", \"React\"]\n}"
            },
            "url": { "raw": "{{baseUrl}}/students", "host": ["{{baseUrl}}"], "path": ["students"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('returns 201', () => pm.response.to.have.status(201));",
                  "pm.test('sets Location header', () => {",
                  "  pm.expect(pm.response.headers.get('Location')).to.match(/\\/api\\/v1\\/students\\/stu_\\d+/);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create student - missing email (422)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"No Email\",\n  \"branch\": \"CS\",\n  \"graduationYear\": 2026\n}"
            },
            "url": { "raw": "{{baseUrl}}/students", "host": ["{{baseUrl}}"], "path": ["students"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('returns 422', () => pm.response.to.have.status(422));",
                  "pm.test('returns field-level details', () => {",
                  "  pm.expect(pm.response.json().error.details.length).to.be.greaterThan(0);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create student - duplicate email (409)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Aarav Sharma 2\",\n  \"email\": \"aarav.sharma@example.edu\",\n  \"branch\": \"CS\",\n  \"graduationYear\": 2026\n}"
            },
            "url": { "raw": "{{baseUrl}}/students", "host": ["{{baseUrl}}"], "path": ["students"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('returns 409', () => pm.response.to.have.status(409));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Companies",
      "item": [
        {
          "name": "List companies",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/companies", "host": ["{{baseUrl}}"], "path": ["companies"] } }
        },
        {
          "name": "List companies - verified=true",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/companies?verified=true",
              "host": ["{{baseUrl}}"],
              "path": ["companies"],
              "query": [{ "key": "verified", "value": "true" }]
            }
          }
        },
        {
          "name": "Get company cmp_001",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/companies/cmp_001", "host": ["{{baseUrl}}"], "path": ["companies", "cmp_001"] } }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "List jobs",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/jobs", "host": ["{{baseUrl}}"], "path": ["jobs"] } }
        },
        {
          "name": "List jobs - filter companyId + type",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/jobs?companyId=cmp_001&type=internship",
              "host": ["{{baseUrl}}"],
              "path": ["jobs"],
              "query": [
                { "key": "companyId", "value": "cmp_001" },
                { "key": "type", "value": "internship" }
              ]
            }
          }
        },
        {
          "name": "Get job with expand=company",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/jobs/job_001?expand=company",
              "host": ["{{baseUrl}}"],
              "path": ["jobs", "job_001"],
              "query": [{ "key": "expand", "value": "company" }]
            }
          }
        }
      ]
    },
    {
      "name": "Applications",
      "item": [
        {
          "name": "List applications",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/applications", "host": ["{{baseUrl}}"], "path": ["applications"] } }
        },
        {
          "name": "Apply - first time with Idempotency-Key (201)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "demo-1" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"studentId\": \"stu_003\",\n  \"jobId\": \"job_002\"\n}" },
            "url": { "raw": "{{baseUrl}}/applications", "host": ["{{baseUrl}}"], "path": ["applications"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('returns 201', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('firstAppId', pm.response.json().data.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Apply - replay same Idempotency-Key (200, same id)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "demo-1" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"studentId\": \"stu_003\",\n  \"jobId\": \"job_002\"\n}" },
            "url": { "raw": "{{baseUrl}}/applications", "host": ["{{baseUrl}}"], "path": ["applications"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('returns 200 on replay', () => pm.response.to.have.status(200));",
                  "pm.test('same id as first call', () => {",
                  "  pm.expect(pm.response.json().data.id).to.equal(pm.collectionVariables.get('firstAppId'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Apply - no key, same student+job (409)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"studentId\": \"stu_003\",\n  \"jobId\": \"job_002\"\n}" },
            "url": { "raw": "{{baseUrl}}/applications", "host": ["{{baseUrl}}"], "path": ["applications"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('returns 409', () => pm.response.to.have.status(409));"
                ]
              }
            }
          ]
        },
        {
          "name": "PATCH application status (200)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"shortlisted\"\n}" },
            "url": { "raw": "{{baseUrl}}/applications/app_001", "host": ["{{baseUrl}}"], "path": ["applications", "app_001"] }
          }
        }
      ]
    },
    {
      "name": "Negative — malformed JSON (400)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{not json" },
        "url": { "raw": "{{baseUrl}}/students", "host": ["{{baseUrl}}"], "path": ["students"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('returns 400 with MALFORMED_JSON', () => {",
              "  pm.response.to.have.status(400);",
              "  pm.expect(pm.response.json().error.code).to.equal('MALFORMED_JSON');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Negative — route not found (404)",
      "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/nonsense", "host": ["{{baseUrl}}"], "path": ["nonsense"] } },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('returns 404 with ROUTE_NOT_FOUND', () => {",
              "  pm.response.to.have.status(404);",
              "  pm.expect(pm.response.json().error.code).to.equal('ROUTE_NOT_FOUND');",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
