{
  "info": {
    "name": "PlaceMux API — Mock (Task 3)",
    "description": "Task 3 mock API with feature-module architecture, standardised query parsing, and nested reads. Set baseUrl to http://localhost:3000/api/v1 before running.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] } },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.response.to.have.status(200));"] } }]
        },
        { "name": "GET /ready", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/ready", "host": ["{{baseUrl}}"], "path": ["ready"] } } }
      ]
    },
    {
      "name": "Students",
      "item": [
        {
          "name": "List (envelope + meta)",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/students", "host": ["{{baseUrl}}"], "path": ["students"] } },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200', () => pm.response.to.have.status(200));",
            "pm.test('envelope', () => { const b = pm.response.json(); pm.expect(b.success).to.be.true; pm.expect(b.data).to.be.an('array'); pm.expect(b.meta.pagination).to.have.property('total'); });"
          ] } }]
        },
        {
          "name": "Filter + sort + sparse fields",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/students?status=seeking&sort=-graduationYear&fields=id,name,graduationYear&limit=5", "host": ["{{baseUrl}}"], "path": ["students"], "query": [
            { "key": "status", "value": "seeking" },
            { "key": "sort", "value": "-graduationYear" },
            { "key": "fields", "value": "id,name,graduationYear" },
            { "key": "limit", "value": "5" }
          ] } }
        },
        {
          "name": "Unknown filter → 400 (strict parsing)",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/students?colour=blue", "host": ["{{baseUrl}}"], "path": ["students"], "query": [{ "key": "colour", "value": "blue" }] } },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('400', () => pm.response.to.have.status(400));",
            "pm.test('code BAD_REQUEST', () => pm.expect(pm.response.json().error.code).to.equal('BAD_REQUEST'));"
          ] } }]
        },
        {
          "name": "Get stu_001",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/students/stu_001", "host": ["{{baseUrl}}"], "path": ["students", "stu_001"] } }
        },
        {
          "name": "Get stu_999 → 404",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/students/stu_999", "host": ["{{baseUrl}}"], "path": ["students", "stu_999"] } },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('404', () => pm.response.to.have.status(404));",
            "pm.test('code RESOURCE_NOT_FOUND', () => pm.expect(pm.response.json().error.code).to.equal('RESOURCE_NOT_FOUND'));"
          ] } }]
        },
        {
          "name": "Create (201 + Location)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Kabir Menon\",\n  \"email\": \"kabir.menon@example.edu\",\n  \"branch\": \"Computer Science\",\n  \"graduationYear\": 2027,\n  \"cgpa\": 8.2,\n  \"skills\": [\"Node.js\", \"React\"]\n}" },
            "url": { "raw": "{{baseUrl}}/students", "host": ["{{baseUrl}}"], "path": ["students"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('201', () => pm.response.to.have.status(201));",
            "pm.test('Location', () => pm.expect(pm.response.headers.get('Location')).to.match(/\\/students\\/stu_\\d+/));"
          ] } }]
        },
        {
          "name": "Missing email → 422",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"No Email\",\n  \"branch\": \"CS\",\n  \"graduationYear\": 2026\n}" },
            "url": { "raw": "{{baseUrl}}/students", "host": ["{{baseUrl}}"], "path": ["students"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('422', () => pm.response.to.have.status(422));",
            "pm.test('details are field-level', () => pm.expect(pm.response.json().error.details.length).to.be.greaterThan(0));"
          ] } }]
        },
        {
          "name": "Duplicate email → 409",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Aarav 2\",\n  \"email\": \"aarav.sharma@example.edu\",\n  \"branch\": \"CS\",\n  \"graduationYear\": 2026\n}" },
            "url": { "raw": "{{baseUrl}}/students", "host": ["{{baseUrl}}"], "path": ["students"] }
          }
        },
        {
          "name": "PATCH stu_001",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"placed\"\n}" },
            "url": { "raw": "{{baseUrl}}/students/stu_001", "host": ["{{baseUrl}}"], "path": ["students", "stu_001"] }
          }
        },
        {
          "name": "Nested: applications for stu_001",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/students/stu_001/applications", "host": ["{{baseUrl}}"], "path": ["students", "stu_001", "applications"] } }
        }
      ]
    },
    {
      "name": "Companies",
      "item": [
        { "name": "List", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/companies", "host": ["{{baseUrl}}"], "path": ["companies"] } } },
        {
          "name": "Filter verified=true",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/companies?verified=true", "host": ["{{baseUrl}}"], "path": ["companies"], "query": [{ "key": "verified", "value": "true" }] } }
        },
        { "name": "Get cmp_001", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/companies/cmp_001", "host": ["{{baseUrl}}"], "path": ["companies", "cmp_001"] } } },
        {
          "name": "Create (201)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Astra Robotics\",\n  \"industry\": \"Robotics\",\n  \"location\": \"Chennai, India\",\n  \"employeeCount\": 85,\n  \"verified\": true\n}" },
            "url": { "raw": "{{baseUrl}}/companies", "host": ["{{baseUrl}}"], "path": ["companies"] }
          }
        },
        {
          "name": "PATCH cmp_001",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"employeeCount\": 500\n}" },
            "url": { "raw": "{{baseUrl}}/companies/cmp_001", "host": ["{{baseUrl}}"], "path": ["companies", "cmp_001"] }
          }
        },
        {
          "name": "Nested: jobs at cmp_001",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/companies/cmp_001/jobs", "host": ["{{baseUrl}}"], "path": ["companies", "cmp_001", "jobs"] } }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        { "name": "List", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/jobs", "host": ["{{baseUrl}}"], "path": ["jobs"] } } },
        {
          "name": "Filter + sort + sparse fields",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/jobs?type=internship&sort=-stipend&fields=id,title,stipend", "host": ["{{baseUrl}}"], "path": ["jobs"], "query": [
            { "key": "type", "value": "internship" }, { "key": "sort", "value": "-stipend" }, { "key": "fields", "value": "id,title,stipend" }
          ] } }
        },
        {
          "name": "Get job_001 with expand=company",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/jobs/job_001?expand=company", "host": ["{{baseUrl}}"], "path": ["jobs", "job_001"], "query": [{ "key": "expand", "value": "company" }] } }
        },
        {
          "name": "Create — deadline in past → 422",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"companyId\": \"cmp_001\",\n  \"title\": \"Old Job\",\n  \"location\": \"Remote\",\n  \"type\": \"internship\",\n  \"deadline\": \"2020-01-01\"\n}" },
            "url": { "raw": "{{baseUrl}}/jobs", "host": ["{{baseUrl}}"], "path": ["jobs"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('422 INV-6', () => pm.response.to.have.status(422));"] } }]
        },
        {
          "name": "Create — bad companyId → 400 (INV-1)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"companyId\": \"cmp_ZZZ\",\n  \"title\": \"Bad\",\n  \"location\": \"Remote\",\n  \"type\": \"internship\",\n  \"deadline\": \"2027-01-01\"\n}" },
            "url": { "raw": "{{baseUrl}}/jobs", "host": ["{{baseUrl}}"], "path": ["jobs"] }
          }
        },
        {
          "name": "Nested: applications for job_001",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/jobs/job_001/applications", "host": ["{{baseUrl}}"], "path": ["jobs", "job_001", "applications"] } }
        }
      ]
    },
    {
      "name": "Applications",
      "item": [
        { "name": "List", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/applications", "host": ["{{baseUrl}}"], "path": ["applications"] } } },
        {
          "name": "Apply with Idempotency-Key (201)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Idempotency-Key", "value": "t3-demo" }],
            "body": { "mode": "raw", "raw": "{\n  \"studentId\": \"stu_003\",\n  \"jobId\": \"job_002\"\n}" },
            "url": { "raw": "{{baseUrl}}/applications", "host": ["{{baseUrl}}"], "path": ["applications"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('201', () => pm.response.to.have.status(201));",
            "pm.collectionVariables.set('firstAppId', pm.response.json().data.id);"
          ] } }]
        },
        {
          "name": "Replay same key → 200, same id",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Idempotency-Key", "value": "t3-demo" }],
            "body": { "mode": "raw", "raw": "{\n  \"studentId\": \"stu_003\",\n  \"jobId\": \"job_002\"\n}" },
            "url": { "raw": "{{baseUrl}}/applications", "host": ["{{baseUrl}}"], "path": ["applications"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200 replay', () => pm.response.to.have.status(200));",
            "pm.test('same id', () => pm.expect(pm.response.json().data.id).to.equal(pm.collectionVariables.get('firstAppId')));"
          ] } }]
        },
        {
          "name": "No key, same student+job → 409",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"studentId\": \"stu_003\",\n  \"jobId\": \"job_002\"\n}" },
            "url": { "raw": "{{baseUrl}}/applications", "host": ["{{baseUrl}}"], "path": ["applications"] }
          }
        },
        {
          "name": "PATCH /:id/status illegal → 409 INVALID_STATE_TRANSITION",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"offered\"\n}" },
            "url": { "raw": "{{baseUrl}}/applications/app_001/status", "host": ["{{baseUrl}}"], "path": ["applications", "app_001", "status"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('409', () => pm.response.to.have.status(409));",
            "pm.test('code INVALID_STATE_TRANSITION', () => pm.expect(pm.response.json().error.code).to.equal('INVALID_STATE_TRANSITION'));"
          ] } }]
        },
        {
          "name": "PATCH /:id/status valid → 200",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"shortlisted\"\n}" },
            "url": { "raw": "{{baseUrl}}/applications/app_001/status", "host": ["{{baseUrl}}"], "path": ["applications", "app_001", "status"] }
          }
        },
        {
          "name": "Withdrawal (sub-resource, 201)",
          "request": { "method": "POST", "url": { "raw": "{{baseUrl}}/applications/app_002/withdrawal", "host": ["{{baseUrl}}"], "path": ["applications", "app_002", "withdrawal"] } }
        },
        {
          "name": "Nested: interviews for app_001",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/applications/app_001/interviews", "host": ["{{baseUrl}}"], "path": ["applications", "app_001", "interviews"] } }
        }
      ]
    },
    {
      "name": "Interviews",
      "item": [
        { "name": "List", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/interviews", "host": ["{{baseUrl}}"], "path": ["interviews"] } } },
        {
          "name": "Create round 3 for app_001 (201)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"applicationId\": \"app_001\",\n  \"round\": 3,\n  \"scheduledAt\": \"2026-08-01T10:00:00Z\"\n}" },
            "url": { "raw": "{{baseUrl}}/interviews", "host": ["{{baseUrl}}"], "path": ["interviews"] }
          }
        },
        {
          "name": "Duplicate round → 409 INV-8",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"applicationId\": \"app_001\",\n  \"round\": 1,\n  \"scheduledAt\": \"2026-08-05T10:00:00Z\"\n}" },
            "url": { "raw": "{{baseUrl}}/interviews", "host": ["{{baseUrl}}"], "path": ["interviews"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('409', () => pm.response.to.have.status(409));"] } }]
        }
      ]
    },
    {
      "name": "Negative — malformed JSON (400)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{not json" },
        "url": { "raw": "{{baseUrl}}/students", "host": ["{{baseUrl}}"], "path": ["students"] }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('400 MALFORMED_JSON', () => { pm.response.to.have.status(400); pm.expect(pm.response.json().error.code).to.equal('MALFORMED_JSON'); });"
      ] } }]
    },
    {
      "name": "Negative — route not found (404)",
      "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/nonsense", "host": ["{{baseUrl}}"], "path": ["nonsense"] } },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('404 ROUTE_NOT_FOUND', () => { pm.response.to.have.status(404); pm.expect(pm.response.json().error.code).to.equal('ROUTE_NOT_FOUND'); });"
      ] } }]
    }
  ]
}
